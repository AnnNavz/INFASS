@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = "Login";
}

<link href="~/css/auth.css" rel="stylesheet" asp-append-version="true" />

<div class="auth-section">
    <div class="auth-card">

        <!-- Header / Logo Area -->
        <div class="auth-header">
            <span class="auth-emoji">🔐</span>
            <h3 class="auth-title">Welcome Back</h3>
            <p class="auth-subtitle">Please sign in to your account</p>
        </div>

        <!-- Error Alert -->
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger" role="alert">
                @ViewBag.ErrorMessage
            </div>
        }

        <!-- Login Form (Updated asp-controller to Login) -->
        <form method="post" asp-action="Login" asp-controller="Login">

            <!-- Username / Email Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="text" class="form-control" id="usernameInput" name="Username" placeholder="Username" required autocomplete="username" />
                    <label for="usernameInput">Username or Email</label>
                </div>
            </div>

            <!-- Password Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="password" class="form-control" id="passwordInput" name="Password" placeholder="Password" required autocomplete="current-password" />
                    <label for="passwordInput">Password</label>
                </div>
            </div>

            <!-- Remember Me & Forgot Password -->
            <div class="auth-options">
                <div class="form-check auth-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe" name="RememberMe" />
                    <label class="form-check-label" for="rememberMe">Remember me</label>
                </div>
                <a href="#" class="auth-link">Forgot password?</a>
            </div>

            <!-- Submit Button -->
            <button id="loginBtn" class="btn btn-primary auth-btn" type="submit">
                Sign In
            </button>

            <!-- Registration Prompt -->
            <div class="auth-footer">
                <span>Don't have an account? </span>
                <a asp-action="Index" asp-controller="Register" class="auth-link">Register</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#loginBtn').click(function (e) {
                e.preventDefault();

                var now = new Date();

                var currentDate = now.toISOString().split('T')[0];

                var currentTime = now.toTimeString().split(' ')[0];

                var formData = {
                    Username: $('#usernameInput').val(),
                    Password: $('#passwordInput').val(),
                    DateIn: currentDate,
                    TimeIn: currentTime
                };

                $.ajax({
                    url: '/Login/Login',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function (response) {
                        alert(response);
                    },
                    error: function (xhr, status, error) {
                        alert("An error occurred: " + xhr.responseText);
                    }
                });
            });
        });
    </script>
}
