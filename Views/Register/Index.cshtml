@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = "Register";
}

<link href="~/css/auth.css" rel="stylesheet" asp-append-version="true" />

<div class="auth-section">
    <div class="auth-card">

        <!-- Header Area -->
        <div class="auth-header">
            <span class="auth-emoji">✨</span>
            <h3 class="auth-title">Create Account</h3>
            <p class="auth-subtitle">Sign up to get started</p>
        </div>

        <!-- Error/Validation Alert (Optional, if you pass errors via ViewBag) -->
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger" role="alert">
                @ViewBag.ErrorMessage
            </div>
        }

        <!-- Registration Form -->
        <form method="post" asp-action="Register" asp-controller="Login">

            <!-- Full Name Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="text" class="form-control" id="nameInput" name="FullName" placeholder="Full Name" required autocomplete="name" />
                    <label for="nameInput">Full Name</label>
                </div>
            </div>

            <!-- Username -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="text" class="form-control" id="usernameInput" name="Username" placeholder="Username" required autocomplete="username" />
                    <label for="usernameInput">Username</label>
                </div>
            </div>

            <!-- Password Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="password" class="form-control" id="passwordInput" name="Password" placeholder="Password" required autocomplete="new-password" />
                    <label for="passwordInput">Password</label>
                </div>
            </div>

            <!-- Confirm Password Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="password" class="form-control" id="confirmPasswordInput" name="ConfirmPassword" placeholder="Confirm Password" required autocomplete="new-password" />
                    <label for="confirmPasswordInput">Confirm Password</label>
                </div>
            </div>

            <!-- Submit Button -->
            <button id="register" class="btn btn-primary auth-btn" type="submit">
                Sign Up
            </button>

            <!-- Login Prompt -->
            <div class="auth-footer">
                <span>Already have an account? </span>
                <a asp-action="Index" asp-controller="Login" class="auth-link">Sign In</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    
    <script>
        $(document).ready(function () {

            $('#register').click(function (e) { 
                e.preventDefault();

                var formData = {
                    FullName: $('#nameInput').val(),
                    Username: $('#usernameInput').val(),
                    Password: $('#passwordInput').val(),
                    ConfirmPassword: $('#confirmPasswordInput').val()
                };

                $.ajax({
                    url: '/Register/SubmitRegistration', 
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData), 
                    success: function (response) {
                        
                        alert(response);
                    },
                    error: function (xhr, status, error) {
                        alert("An error occurred: " + xhr.responseText);
                    }
                });
            });
        });
    </script>
}
