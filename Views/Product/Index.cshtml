@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = "Add Product";
}

<link href="~/css/auth.css" rel="stylesheet" asp-append-version="true" />

<div class="auth-section">
    <div class="auth-card">

        <!-- Header Area -->
        <div class="auth-header">
            <span class="auth-emoji">📦</span>
            <h3 class="auth-title">Add Product</h3>
            <p class="auth-subtitle">Enter product details below</p>
        </div>

        <!-- Error/Validation Alert -->
        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert alert-danger" role="alert">
                @ViewBag.ErrorMessage
            </div>
        }

        <!-- Product Form -->
        <form method="post" asp-action="AddProduct" asp-controller="Product">

            <!-- Product Name Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="text" class="form-control" id="productNameInput" name="ProductName" placeholder="Product Name" required />
                    <label for="productNameInput">Product Name</label>
                </div>
            </div>

            <!-- Description Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <textarea class="form-control" id="descriptionInput" name="Description" placeholder="Description" style="height: 100px;"></textarea>
                    <label for="descriptionInput">Description</label>
                </div>
            </div>

            <!-- Price Input -->
            <div class="auth-field">
                <div class="form-floating">
                    <input type="number" step="0.01" min="0" class="form-control" id="priceInput" name="Price" placeholder="Price" required />
                    <label for="priceInput">Price</label>
                </div>
            </div>

            <!-- Submit Button -->
            <button id="saveProduct" class="btn btn-primary auth-btn" type="submit">
                Save Product
            </button>

            <!-- Footer Link -->
            <div class="auth-footer">
                <a asp-action="Index" asp-controller="Product" class="auth-link">Back to Products</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

            $('#saveProduct').click(function (e) {
                e.preventDefault();

                var formData = {
                    ProductName: $('#productNameInput').val(),
                    ProductDescription: $('#descriptionInput').val(),
                    Price: parseFloat($('#priceInput').val()) || 0
                };

                $.ajax({
                    url: '/Product/AddProduct',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(formData),
                    success: function (response) {
                        alert(response);
                    },
                    error: function (xhr, status, error) {
                        alert("An error occurred: " + xhr.responseText);
                    }
                });
            });
        });
    </script>
}